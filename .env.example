NODE_ENV=development
PORT=5000

# Used to build password-reset links that point back to the frontend
CLIENT_URL=http://localhost:5173

# MongoDB Atlas connection string (see SETUP.md for how to get this)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/ems?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Cloudinary (for document/profile picture uploads - set up later)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Nodemailer (for password reset / notification emails - set up later)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
